# Optional manual override for production DBmate commands.
#
# Normal `make db-status-prod`, `make db-migrate-prod`, and `make psql-prod`
# runs resolve the Render Postgres URL from the Render API, so this file is not
# needed after Blueprint creation. If you need to bypass Render discovery, export
# this variable in your shell before running the command.
DBMATE_PROD_DATABASE_URL="postgres://USER:PASSWORD@HOST.virginia-postgres.render.com:5432/pystack_prod?sslmode=require"
