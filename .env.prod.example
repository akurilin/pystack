# Production database URL for dbmate, used by `make db-migrate-prod`.
# Copy this file to .env.prod (gitignored) and fill in the real credential.
#
# Use the EXTERNAL connection string from the Render dashboard (it ends in
# .virginia-postgres.render.com), switch the scheme to postgres://, and append
# ?sslmode=require — Render requires TLS for external connections.
DBMATE_PROD_DATABASE_URL="postgres://USER:PASSWORD@HOST.virginia-postgres.render.com:5432/pystack_prod?sslmode=require"
