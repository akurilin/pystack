POSTGRES_PORT=5432
PYSTACK_DATABASE_URL=postgresql://pystack:pystack@localhost:5432/pystack_dev
PYSTACK_TEST_DATABASE_URL=postgresql://pystack:pystack@localhost:5432/pystack_test
PYSTACK_CORS_ORIGINS=["http://localhost:5173"]
PYSTACK_ASSISTANT_MODEL=openai/gpt-oss-20b:free
PYSTACK_OPENROUTER_API_KEY=...

# Clerk authentication (required — the app has no anonymous mode).
# Create a Clerk dev instance at https://dashboard.clerk.com and copy its keys.
PYSTACK_CLERK_SECRET_KEY=sk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Sentry error monitoring (optional in dev — leave blank to disable).
# In production these are set in the Render dashboard, not from this file.
VITE_SENTRY_DSN=
PYSTACK_SENTRY_DSN=

# Dedicated Clerk test user for the Playwright e2e suite (make test-e2e).
# Configure this user without MFA/device verification so a scripted password
# sign-in completes in one step.
CLERK_TEST_USER_USERNAME=...
CLERK_TEST_USER_PASSWORD=...
