#!/bin/sh
set -eu

# Run the psql client from the compose `db` service so a local psql install
# isn't required. Unlike bin/pg_dump this omits `-T`, letting Docker allocate a
# TTY for an interactive session.
repo_root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)

exec docker compose \
    --project-directory "$repo_root" \
    -f "$repo_root/compose.yaml" \
    exec db psql "$@"
